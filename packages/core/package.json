{
  "name": "@aiengineercv/core",
  "version": "0.1.0",
  "description": "The shared brain: Profile schema, AI taxonomy, scoring rubric, generation spec, and deterministic scorer/guardrail used by every adapter.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./assets/*": "./assets/*"
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "gen": "node ../../scripts/gen-core-assets.mjs",
    "build": "pnpm gen && tsc -p tsconfig.json",
    "typecheck": "pnpm gen && tsc -p tsconfig.json --noEmit",
    "test": "pnpm gen && vitest run"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "vitest": "^2.0.5"
  }
}
