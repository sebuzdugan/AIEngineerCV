# Copy to .env (local) or set these in the Vercel project's Environment Variables.
# NONE of these ever reach the browser - they live only on the server.

# OpenRouter (your key - ROTATE the one you pasted in chat and use a fresh one here)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxx
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324

# Signing secret for the email-verified token (any long random string)
TOKEN_SECRET=change-me-to-a-long-random-string

# Resend (email codes). Verify the frai.cc domain in Resend, then send from it.
RESEND_API_KEY=re_xxxxxxxx
FROM_EMAIL=AIEngineerCV <noreply@frai.cc>

# Upstash Redis (try counts + codes + rate limits). Vercel KV also works (KV_REST_API_*).
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxx

# Optional tuning
ALLOWED_ORIGINS=https://sebuzdugan.github.io,http://localhost:5173
INITIAL_FREE_TRIES=1
FOLLOW_BONUS=2
