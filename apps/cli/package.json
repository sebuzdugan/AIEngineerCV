{
  "name": "aiengineercv",
  "version": "0.1.0",
  "description": "AIEngineerCV CLI (aicv): turn your raw materials into a sharp, role-targeted AI-engineering CV. Bring your own key.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "aicv": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "node --import tsx src/index.ts"
  },
  "dependencies": {
    "@aiengineercv/core": "workspace:*",
    "@anthropic-ai/sdk": "^0.68.0",
    "commander": "^12.1.0",
    "mammoth": "^1.8.0",
    "picocolors": "^1.1.0",
    "pdf-parse": "^1.1.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/prompts": "^2.4.9",
    "tsx": "^4.19.0"
  },
  "keywords": ["cv", "resume", "ai-engineer", "cli"]
}
